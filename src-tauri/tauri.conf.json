{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DCleaner",
  "version": "0.1.0",
  "identifier": "com.dcleaner.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DCleaner",
        "width": 1180,
        "height": 760,
        "minWidth": 1180,
        "minHeight": 760,
        "maxWidth": 1180,
        "maxHeight": 760,
        "resizable": false,
        "maximizable": false,
        "center": true,
        "decorations": false,
        "transparent": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": []
  }
}
